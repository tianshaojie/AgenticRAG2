# Copy to .env and fill in real values
APP_NAME=AgenticRAG
APP_VERSION=0.2.0
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_rag
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# pgvector
VECTOR_DIMENSION=1536
VECTOR_DISTANCE_METRIC=cosine
VECTOR_INDEX_TYPE=hnsw
HNSW_M=16
HNSW_EF_CONSTRUCTION=64

# Retrieval
RETRIEVAL_TOP_K=10
# Minimum cosine similarity score to include a chunk (0.0–1.0)
RETRIEVAL_SCORE_THRESHOLD=0.7

# Agent
MAX_AGENT_STEPS=5

# Chunking (Step 2)
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
CHUNK_MIN_TOKENS=20

# Embedding (Step 2)
# Options: deterministic_stub (no API key needed) | openai
EMBEDDING_PROVIDER=deterministic_stub
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=3

# Ingestion (Step 2)
MAX_UPLOAD_SIZE_BYTES=52428800

# Answer generation (Step 2)
# Options: echo_stub (no LLM) | openai (Step 4)
ANSWER_PROVIDER=echo_stub
# Minimum retrieved chunks required to generate (else abstain)
MIN_EVIDENCE_CHUNKS=1

# LLM (Step 4 — leave empty for Step 2)
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console
